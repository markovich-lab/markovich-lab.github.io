---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Team",
	description: "Meet the lab members",
};

const team = [
	{
		name: "Dr. Katie Markovich",
		role: "Principal Investigator",
		bio: "Focuses on numerical modeling and data analysis.",
		img: "/images/Katie_Markovich_2.jpg",
		email: "kmarkovich@unm.edu",
		github: "kmarkovich",
		googlescholar: "https://scholar.google.com/citations?user=DR6_ChQAAAAJ&hl=en",
		cv: "/files/markovich_cv_mar2025.pdf",
	},
	{
		name: "Mackenzie Hannan-Stamey",
		role: "PhD Student · Starting Fall 2026",
		bio: "",
		img: "",
	},
	{
		name: "Elizabeth Lindsey",
		role: "MS Student · Starting Fall 2026",
		bio: "",
		img: "",
	},
];
---

<PageLayout meta={meta}>
	<h1 class="title mb-4">Team</h1>
	<p class="text-muted mb-8">
		Our lab works on groundwater sustainability, modeling, and policy-relevant science.
	</p>

	<div class="mx-auto max-w-4xl px-4">
		<ul class="flex flex-col gap-6" role="list">
			{
				team.map((m) => (
					<li class="bg-card flex items-start gap-6 rounded-lg p-6 shadow-sm">
						{m.img ? <img src={m.img} alt={m.name} class="h-36 w-36 flex-shrink-0 rounded-md object-cover" /> : <div class="h-36 w-36 flex-shrink-0 rounded-md bg-gray-200 dark:bg-gray-700" />}

						<div class="min-w-0 flex-1">
							<h3 class="text-xl leading-tight font-semibold">{m.name}</h3>
							<p class="text-muted text-sm">{m.role}</p>
							<p class="text-muted mt-3 text-sm">{m.bio}</p>

							<div class="mt-4 flex items-center gap-3">
								{m.email ? (
									<a
										href={`mailto:${m.email}`}
										aria-label={`Email ${m.name}`}
										class="text-muted hover:text-accent"
									>
										<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden>
											<path
												d="M3 8.5v7A2.5 2.5 0 0 0 5.5 18h13A2.5 2.5 0 0 0 21 15.5v-7"
												stroke="currentColor"
												stroke-width="1.5"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
											<path
												d="M21 8.5l-9 6-9-6"
												stroke="currentColor"
												stroke-width="1.5"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
									</a>
								) : null}

								{m.github ? (
									<a
										href={`https://github.com/${m.github}`}
										target="_blank"
										rel="noreferrer"
										aria-label={`${m.name} GitHub`}
										class="text-muted hover:text-accent"
									>
										<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden>
											<path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.71-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1.01.07 1.54 1.04 1.54 1.04.9 1.54 2.36 1.1 2.94.84.09-.65.35-1.1.64-1.35-2.22-.25-4.56-1.11-4.56-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0 1 12 6.8c.85.004 1.71.115 2.51.34 1.9-1.29 2.74-1.02 2.74-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.86-2.34 4.7-4.57 4.95.36.31.68.92.68 1.85 0 1.33-.01 2.4-.01 2.73 0 .27.18.58.69.48A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10z" />
										</svg>
									</a>
								) : null}

								{m.googlescholar ? (
									<a
										href={m.googlescholar}
										target="_blank"
										rel="noreferrer"
										aria-label={`${m.name} Google Scholar`}
										class="text-muted hover:text-accent"
									>
										<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden>
											<path d="M12 2L2 7l10 5 10-5-10-5z" />
											<path
												d="M4.5 9.6v4.9c0 3.2 3.6 5.6 7.5 5.6s7.5-2.4 7.5-5.6v-4.9"
												fill="none"
												stroke="currentColor"
												stroke-width="0.6"
											/>
										</svg>
									</a>
								) : null}

								{m.cv ? (
									<a
										href={m.cv}
										target="_blank"
										rel="noreferrer"
										aria-label={`${m.name} CV`}
										class="text-muted hover:text-accent inline-flex"
									>
										<span class="bg-accent inline-flex h-6 w-8 items-center justify-center rounded text-xs font-semibold text-white">
											CV
										</span>
									</a>
								) : null}
							</div>
						</div>
					</li>
				))
			}
		</ul>
	</div>
</PageLayout>
