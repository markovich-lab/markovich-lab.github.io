---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Page describing opportunities to join lab",
	title: "Opportunities",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-8">Interested in joining the lab?</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			Funded opportunities will be posted here as they become available.
			If there are no current postings, don't despair — there may still be opportunities to join the lab through a teaching assistantship.
		</p>
		<p>The typical timeline for applying to the MS or PhD program in the UNM Earth &amp; Planetary Sciences Department:</p>
	</div>

	<ol class="mt-6 flex flex-col gap-0" role="list">
		{[
			{ when: "Fall semester", what: "Reach out to Dr. Markovich by email with your CV/resume and a brief introduction expressing your interest and background." },
			{ when: "Early January", what: "Deadline to apply to the UNM EPS Department. Only applicants who have established compatibility and funding availability with Dr. Markovich will be considered." },
			{ when: "March", what: "Offers extended. Admitted students are invited for a campus visit to meet the department and Markovich Lab." },
			{ when: "Mid-April", what: "Deadline to accept or decline your offer." },
			{ when: "Following Fall", what: "Start the program!" },
		].map((step, i) => (
			<li class="relative flex gap-4 pb-8 last:pb-0">
				<div class="flex flex-col items-center">
					<div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-white">
						{i + 1}
					</div>
					<div class="mt-1 w-px flex-1 bg-gray-300 last:hidden dark:bg-gray-600" />
				</div>
				<div class="pb-2 pt-1">
					<p class="text-sm font-semibold text-accent">{step.when}</p>
					<p class="mt-0.5 text-sm">{step.what}</p>
				</div>
			</li>
		))}
	</ol>
</PageLayout>
